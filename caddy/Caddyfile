# WHY both blocks must be in this file:
# Caddy's config is a single file. When this is deployed, it REPLACES whatever
# was on the server before. If we only put the counter block here, the hello-world
# routing would disappear. Both services share the same Caddy instance on each
# server, so both must appear in the same Caddyfile.

hello-world.rishi.yral.com {
    tls internal
    reverse_proxy yral-hello-world-rishi:8000
}

hello-world-counter.rishi.yral.com {
    tls internal
    reverse_proxy yral-hello-world-counter:8000
}
